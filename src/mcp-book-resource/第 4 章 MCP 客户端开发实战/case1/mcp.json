{
	"mcpServers": {
		"weather-mcp": {
			"command": "npx",
			"args": ["-y", "@chatmcp/weather-mcp"],
			"env": {
				"WEATHER_API_KEY": "xxx"
			}
		},
		"flomo-mcp": {
			"command": "npx",
			"args": ["-y", "@chatmcp/flomo-mcp"],
			"env": {
				"FLOMO_API_URL": "https://flomoapp.com/iwh/xxx/xxxxxx/"
			}
		}
	}
}